{
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"name": "@allons-y/stylelint-header",
	"version": "4.0.0",
	"description": "A stylelint plugin that checks for a file header.",
	"license": "MPL-2.0",
	"author": "Cassondra Roberts <castastrophe@users.noreply.github.com> (https://allons-y.studio)",
	"funding": [
		{
			"type": "github",
			"url": " https://github.com/sponsors/castastrophe"
		},
		{
			"type": "buymeacoffee",
			"url": "https://www.buymeacoffee.com/castastrophe"
		}
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/allonsy-studio/stylelint-header.git"
	},
	"bugs": {
		"url": "https://github.com/allonsy-studio/stylelint-header/issues"
	},
	"type": "module",
	"exports": "./index.js",
	"module": "index.js",
	"files": [
		"index.js",
		"!test/*",
		"README.md",
		"CHANGELOG.md",
		"package.json",
		"LICENSE"
	],
	"scripts": {
		"changeset": "changeset",
		"coverage": "yarn test --coverage --coverageReporters=cobertura",
		"format": "yarn lint --fix",
		"lint": "eslint --no-error-on-unmatched-pattern --no-warn-ignored --cache '**/*'",
		"postpack": "pinst --enable",
		"prepack": "pinst --disable",
		"prepare": "husky && envoy || true",
		"prepublish": "yarn test",
		"test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
		"watch": "yarn test --watch"
	},
	"dependencies": {
		"lodash-es": "4.18.1",
		"string-similarity": "4.0.4"
	},
	"peerDependencies": {
		"stylelint": "17.x"
	},
	"devDependencies": {
		"@allons-y/envoy": "^1.1.0",
		"@changesets/cli": "^2.31.0",
		"@changesets/get-github-info": "^0.8.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^1.2.0",
		"@eslint/markdown": "^8.0.2",
		"@stylistic/eslint-plugin": "^2.13.0",
		"cross-env": "10.1.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jest": "^29.15.4",
		"eslint-plugin-jsonc": "^3.2.0",
		"eslint-plugin-node": "^11.1.0",
		"globals": "^17.6.0",
		"husky": "9.1.7",
		"jest": "30.3.0",
		"jest-preset-stylelint": "9.1.0",
		"lint-staged": "^17.0.4",
		"pinst": "3.0.0",
		"prettier": "^3.8.3",
		"stylelint": "17.9.1"
	},
	"keywords": [
		"css",
		"header",
		"linter",
		"stylelint",
		"stylelint-plugin"
	],
	"engines": {
		"node": ">=24"
	},
	"jest": {
		"preset": "jest-preset-stylelint"
	},
	"lint-staged": {
		"*": [
			"eslint --fix --format stylish",
			"prettier --write --ignore-unknown --no-error-on-unmatched-pattern --no-warn-ignored"
		],
		".github/renovate.json": "npx --yes --package renovate -- renovate-config-validator --strict"
	},
	"packageManager": "yarn@4.17.1"
}
